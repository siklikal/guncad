# ===================
# Supabase
# ===================
PUBLIC_SUPABASE_URL=
PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ===================
# Auth
# ===================
# Secret pepper used to hash account numbers for lookup tokens (hex, 64+ chars)
# Generate with: openssl rand -hex 64
ACCOUNT_NUMBER_PEPPER=

# Shared password for beta site access gate
BETA_ACCESS_PASSWORD=

# ===================
# LBRY file server
# ===================
LBRY_SERVER_URL=

# ===================
# Authorize.Net payments
# Uncomment ONE block (sandbox or production)
# ===================

# --- SANDBOX ---
ADN_TRANSACTION_KEY=
ADN_API_ENDPOINT=https://apitest.authorize.net/xml/v1/request.api
PUBLIC_ADN_API_LOGIN_ID=
PUBLIC_ADN_PUBLIC_CLIENT_KEY=
PUBLIC_ADN_ACCEPT_JS_URL=https://jstest.authorize.net/v1/Accept.js

# --- PRODUCTION ---
# ADN_TRANSACTION_KEY=
# ADN_API_ENDPOINT=https://api.authorize.net/xml/v1/request.api
# PUBLIC_ADN_API_LOGIN_ID=
# PUBLIC_ADN_PUBLIC_CLIENT_KEY=
# PUBLIC_ADN_ACCEPT_JS_URL=https://js.authorize.net/v1/Accept.js

# Test card (sandbox only, pre-fills the payment form — remove for production)
PUBLIC_ADN_TEST_CARD_NUMBER=
PUBLIC_ADN_TEST_CARD_CODE_NUMBER=
PUBLIC_ADN_TEST_CARD_EXPIRATION_MONTH=
PUBLIC_ADN_TEST_CARD_EXPIRATION_YEAR=
PUBLIC_ADN_TEST_CARD_ZIP_CODE=

# ===================
# Pricing
# ===================
PUBLIC_MODEL_PURCHASE_PRICE=5.00

# ===================
# Geo / VPN detection
# ===================
IPGEOLOCATION_API_KEY=
VPNAPI_API_KEY=
# Set to true to skip geo/VPN checks during development
BYPASS_GEO_CHECK=true
